# ===== Buyunaihe Docker Compose environment =====
# Copy this file to deploy/docker.env and edit before deploying:
#   cp deploy/docker.env.example deploy/docker.env        (Linux/macOS)
#   Copy-Item deploy/docker.env.example deploy/docker.env (Windows PowerShell)

# ---- Host port mappings (host-side ports for accessing from browser/host) ----
# Defaults avoid common conflicts with locally-running MySQL/Redis/web servers.
# Internal service-to-service traffic uses the Docker network and is unaffected.
FRONTEND_HOST_PORT=8088
MYSQL_HOST_PORT=3307
REDIS_HOST_PORT=6380

# ---- MySQL ----
# 必填：设置强密码，留空会导致 MySQL 容器无法启动
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=labelhub
MYSQL_USER=labelhub
MYSQL_PASSWORD=

# ---- Redis ----
# (no password by default; service is internal)

# ---- RabbitMQ ----
RABBITMQ_USER=labelhub
RABBITMQ_PASSWORD=

# ---- MinIO ----
MINIO_ROOT_USER=labelhub
MINIO_ROOT_PASSWORD=
# Public URL the browser uses to download exported files / uploaded assets.
# In Docker, MinIO API is published on host port 9000.
LABELHUB_MINIO_PUBLIC_URL=http://localhost:9000

# ---- Backend security ----
# 必填：JWT 签名密钥，建议使用随机字符串（如 openssl rand -hex 32）
JWT_SECRET=

# ---- 应用初始管理员（首次启动自动创建，之后请登录修改）----
# 留空则首次启动时自动生成随机密码并打印到 backend 日志
APP_ADMIN_PASSWORD=

# ---- AI Agent (optional) ----
# Leave AI_AUDIT_API_KEY empty to run in rule-based / heuristic mode (no external LLM).
# To enable real LLM, fill an OpenAI-compatible endpoint:
AI_AUDIT_BASE_URL=
AI_AUDIT_API_KEY=
AI_AUDIT_MODEL=gpt-4o-mini

# ---- Agent pip mirror (only used at image build time, optional) ----
# AGENT_PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# AGENT_PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
# AGENT_PIP_DEFAULT_TIMEOUT=180
